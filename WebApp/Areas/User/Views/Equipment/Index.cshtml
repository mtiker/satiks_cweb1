@model IEnumerable<App.DTO.v1.EquipmentDto>
@{
    ViewData["Title"] = Localizer["Equipment"];
}

<div class="container mt-4">
    <h2 class="mb-3">@Localizer["Equipment"]</h2>

    <div class="table-responsive">
        <table class="table table-striped align-middle">
            <thead>
                <tr>
                    <th>@Localizer["Name"]</th>
                    <th>@Localizer["Category"]</th>
                    <th>@Localizer["Laboratory"]</th>
                    <th>@Localizer["Condition"]</th>
                    <th>@Localizer["Status"]</th>
                    <th class="text-end">@Localizer["Actions"]</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted py-4">@Localizer["NoRecordsFound"]</td>
                    </tr>
                }
                else
                {
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Name</td>
                            <td>@item.CategoryName</td>
                            <td>@item.LaboratoryName</td>
                            <td>@item.EquipmentCondition</td>
                            <td>
                                @if (item.IsAvailableForBooking)
                                {
                                    <span class="badge bg-success">@Localizer["Available"]</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">@Localizer["Unavailable"]</span>
                                }
                            </td>
                            <td class="text-end">
                                <a asp-area="User" asp-action="Details" asp-controller="Equipment" asp-route-id="@item.Id"
                                   class="btn btn-sm btn-outline-primary">
                                    @Localizer["Details"]
                                </a>
                                @if (item.IsAvailableForBooking && User.Identity?.IsAuthenticated == true)
                                {
                                    <a asp-area="User" asp-controller="Booking" asp-action="Create"
                                       asp-route-equipmentId="@item.Id" class="btn btn-sm btn-success ms-1">
                                        @Localizer["Book"]
                                    </a>
                                }
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
