@model BookingCreateViewModel
@{
    ViewData["Title"] = Localizer["NewBooking"];
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <h2>@Localizer["NewBooking"]</h2>

            <form asp-area="User" asp-action="Create" asp-controller="Booking" method="post">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="EquipmentId" class="form-label">@Localizer["Equipment"]</label>
                    <select asp-for="EquipmentId" asp-items="Model.EquipmentSelectList"
                            class="form-select">
                        <option value="">-- Select Equipment --</option>
                    </select>
                    <span asp-validation-for="EquipmentId" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="StartTime" class="form-label">@Localizer["StartTime"]</label>
                    <input asp-for="StartTime" type="datetime-local" class="form-control" />
                    <span asp-validation-for="StartTime" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="EndTime" class="form-label">@Localizer["EndTime"]</label>
                    <input asp-for="EndTime" type="datetime-local" class="form-control" />
                    <span asp-validation-for="EndTime" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Purpose" class="form-label">@Localizer["Purpose"]</label>
                    <textarea asp-for="Purpose" class="form-control" rows="3"></textarea>
                    <span asp-validation-for="Purpose" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-primary">@Localizer["Save"]</button>
                <a asp-area="User" asp-action="Index" asp-controller="Booking" class="btn btn-outline-secondary ms-2">@Localizer["Cancel"]</a>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}
