@model TrainingCertFormViewModel

@{
    ViewData["Title"] = Localizer["EditCertification"];
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-header bg-warning text-dark">
                <h4 class="mb-0">
                    <i class="bi bi-pencil me-2"></i>@Localizer["EditCertification"]
                </h4>
            </div>
            <div class="card-body">
                <form asp-area="User" asp-action="Edit" asp-controller="TrainingCertification"
                      asp-route-id="@Model.Id" method="post">
                    <input type="hidden" asp-for="Id" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger d-none" id="valSummary"></div>
                    <script>
                        document.addEventListener('DOMContentLoaded', function () {
                            var vs = document.getElementById('valSummary');
                            if (vs && vs.querySelector('ul li')) vs.classList.remove('d-none');
                        });
                    </script>

                    <div class="mb-3">
                        <label asp-for="EquipmentCategoryId" class="form-label fw-semibold">
                            @Localizer["EquipmentCategory"] <span class="text-danger">*</span>
                        </label>
                        <select asp-for="EquipmentCategoryId" asp-items="Model.CategorySelectList"
                                class="form-select">
                            <option value="">— @Localizer["SelectCategory"] —</option>
                        </select>
                        <span asp-validation-for="EquipmentCategoryId" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="CertifiedDate" class="form-label fw-semibold">
                            @Localizer["CertifiedDate"] <span class="text-danger">*</span>
                        </label>
                        <input asp-for="CertifiedDate" class="form-control" type="date" />
                        <span asp-validation-for="CertifiedDate" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ExpiryDate" class="form-label fw-semibold">
                            @Localizer["ExpiryDate"]
                        </label>
                        <input asp-for="ExpiryDate" class="form-control" type="date" />
                        <span asp-validation-for="ExpiryDate" class="text-danger small"></span>
                        <div class="form-text">@Localizer["ExpiryDateHint"]</div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="CertificateReference" class="form-label fw-semibold">
                            @Localizer["CertificateReference"]
                        </label>
                        <input asp-for="CertificateReference" class="form-control"
                               placeholder="e.g. CERT-2026-001" />
                        <span asp-validation-for="CertificateReference" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2 mt-3">
                        <button type="submit" class="btn btn-warning">
                            <i class="bi bi-save me-1"></i>@Localizer["Save"]
                        </button>
                        <a asp-area="User" asp-action="Index" asp-controller="TrainingCertification"
                           class="btn btn-secondary">@Localizer["Cancel"]</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
