@model IEnumerable<App.DTO.v1.TrainingCertificationDto>
@{
    ViewData["Title"] = Localizer["MyCertifications"];
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="mb-0">@Localizer["MyCertifications"]</h2>
        <a asp-area="User" asp-action="Create" asp-controller="TrainingCertification" class="btn btn-primary">
            @Localizer["AddCertification"]
        </a>
    </div>

    <div class="table-responsive">
        <table class="table table-striped align-middle">
            <thead>
                <tr>
                    <th>@Localizer["EquipmentCategory"]</th>
                    <th>@Localizer["CertifiedDate"]</th>
                    <th>@Localizer["ExpiryDate"]</th>
                    <th>@Localizer["Status"]</th>
                    <th>@Localizer["CertificateReference"]</th>
                    <th class="text-end">@Localizer["Actions"]</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted py-4">@Localizer["NoRecordsFound"]</td>
                    </tr>
                }
                else
                {
                    @foreach (var item in Model)
                    {
                        var badgeClass = item.Status switch
                        {
                            "Approved" => "success",
                            "Pending"  => "warning",
                            "Rejected" => "danger",
                            "Revoked"  => "danger",
                            "Expired"  => "secondary",
                            _          => "secondary"
                        };
                        <tr>
                            <td>@item.EquipmentCategoryName</td>
                            <td>@item.CertifiedDate.ToString("d")</td>
                            <td>@(item.ExpiryDate?.ToString("d") ?? "-")</td>
                            <td><span class="badge bg-@badgeClass">@item.Status</span></td>
                            <td>@(item.CertificateReference ?? "-")</td>
                            <td class="text-end">
                                <a asp-area="User" asp-action="Details" asp-controller="TrainingCertification"
                                   asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">@Localizer["Details"]</a>
                                @if (item.Status == "Pending")
                                {
                                    <a asp-area="User" asp-action="Edit" asp-controller="TrainingCertification"
                                       asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning ms-1">@Localizer["Edit"]</a>
                                    <a asp-area="User" asp-action="Delete" asp-controller="TrainingCertification"
                                       asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger ms-1">@Localizer["Delete"]</a>
                                }
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>
