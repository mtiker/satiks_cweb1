@model App.DTO.v1.DepartmentDto
@{ ViewData["Title"] = Localizer["DeleteDepartment"]; }

<h2>@Localizer["DeleteDepartment"]</h2>
<div class="alert alert-danger">@Localizer["ConfirmDeleteDepartment", Model.Name]</div>
<dl class="row">
    <dt class="col-sm-3">@Localizer["Name"]</dt><dd class="col-sm-9">@Model.Name</dd>
    <dt class="col-sm-3">@Localizer["CostCenter"]</dt><dd class="col-sm-9">@Model.CostCenter</dd>
</dl>
<form asp-action="Delete">
    <input type="hidden" name="id" value="@Model.Id" />
    <button type="submit" class="btn btn-danger">@Localizer["Delete"]</button>
    <a asp-action="Index" class="btn btn-secondary">@Localizer["Cancel"]</a>
</form>