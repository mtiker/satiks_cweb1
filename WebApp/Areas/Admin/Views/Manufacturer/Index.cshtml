@model WebApp.Areas.Admin.ViewModels.Manufacturer.ManufacturerIndexViewModel

@{
    ViewData["Title"] = Localizer["Manufacturers"];
}

@await Html.PartialAsync("_PageHeader", new WebApp.ViewModels.Shared.PageHeaderViewModel(
    Localizer["Manufacturers"],
    Localizer["CreateManufacturer"],
    Url.Action("Create")))

@await Html.PartialAsync("_SearchFilterBar", Model.FilterState)

@await Component.InvokeAsync("DataTable", new {
    rowsPartial = "~/Areas/Admin/Views/Manufacturer/_Rows.cshtml",
    model       = Model.Items,
    config      = new WebApp.ViewModels.Shared.DataTableConfig
    {
        Columns =
        [
            Localizer["Name"],
            Localizer["Country"],
            Localizer["Website"],
            Localizer["SupportPhone"],
            Localizer["SupportEmail"]
        ]
    }
})

@await Html.PartialAsync("_PaginationBar", Model)
