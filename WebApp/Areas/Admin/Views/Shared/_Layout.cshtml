<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — LabTrack Admin</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <style>
        .sidebar .nav-link:hover { background-color: rgba(255,255,255,.1); border-radius: .25rem; }
        .sidebar .nav-link.active { background-color: rgba(255,255,255,.2); border-radius: .25rem; }
    </style>
</head>
<body>
<div class="container-fluid">
    <div class="row">
        @await Html.PartialAsync("_AdminSidebar")
        <main class="col-md-10 ms-sm-auto px-4 py-3">
            <div class="d-flex justify-content-end align-items-center gap-2 mb-3">

                @{
                    var currentCulture = System.Globalization.CultureInfo.CurrentUICulture.Name;
                    var returnUrl = Context.Request.Path + Context.Request.QueryString;
                }
                <div class="btn-group btn-group-sm" role="group" aria-label="Language">
                    <form asp-area="" asp-controller="SetLanguage" asp-action="Set" method="post" class="d-inline">
                        <input type="hidden" name="culture" value="et-EE" />
                        <input type="hidden" name="returnUrl" value="@returnUrl" />
                        <button type="submit" class="btn @(currentCulture == "et-EE" ? "btn-secondary" : "btn-outline-secondary")">
                            ET
                        </button>
                    </form>
                    <form asp-area="" asp-controller="SetLanguage" asp-action="Set" method="post" class="d-inline">
                        <input type="hidden" name="culture" value="en-GB" />
                        <input type="hidden" name="returnUrl" value="@returnUrl" />
                        <button type="submit" class="btn @(currentCulture == "en-GB" ? "btn-secondary" : "btn-outline-secondary")">
                            EN
                        </button>
                    </form>
                </div>

                <form asp-area="User" asp-controller="Account" asp-action="Logout" method="post" class="d-inline">
                    <button type="submit" class="btn btn-outline-danger btn-sm">
                        <i class="bi bi-box-arrow-right me-1"></i>Log Out
                    </button>
                </form>
            </div>
            <nav aria-label="breadcrumb" class="mb-2">
                <ol class="breadcrumb">
                    <li class="breadcrumb-item"><a asp-area="Admin" asp-controller="Home" asp-action="Index">Admin</a></li>
                    <li class="breadcrumb-item">@ViewContext.RouteData.Values["controller"]</li>
                    <li class="breadcrumb-item active" aria-current="page">@ViewContext.RouteData.Values["action"]</li>
                </ol>
            </nav>
            @if (TempData["Success"] is string success)
            {
                <div class="alert alert-success alert-dismissible fade show" role="alert">
                    <i class="bi bi-check-circle-fill me-2"></i>@success
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @if (TempData["Error"] is string error)
            {
                <div class="alert alert-danger alert-dismissible fade show" role="alert">
                    <i class="bi bi-exclamation-triangle-fill me-2"></i>@error
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }
            @RenderBody()
        </main>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>