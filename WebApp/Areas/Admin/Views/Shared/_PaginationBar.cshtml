@model WebApp.ViewModels.Shared.PagedListViewModel
@if (Model.TotalPages > 1)
{
    <nav aria-label="Page navigation" class="mt-3">
        <ul class="pagination justify-content-center">
            <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                <a class="page-link" asp-route-page="@(Model.Page - 1)">
                    <i class="bi bi-chevron-left"></i> Previous
                </a>
            </li>
            @for (int i = Math.Max(1, Model.Page - 2); i <= Math.Min(Model.TotalPages, Model.Page + 2); i++)
            {
                <li class="page-item @(i == Model.Page ? "active" : "")">
                    <a class="page-link" asp-route-page="@i">@i</a>
                </li>
            }
            <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                <a class="page-link" asp-route-page="@(Model.Page + 1)">
                    Next <i class="bi bi-chevron-right"></i>
                </a>
            </li>
        </ul>
        <p class="text-center text-muted small mt-1">
            Page @Model.Page of @Model.TotalPages — @Model.TotalCount total records
        </p>
    </nav>
}