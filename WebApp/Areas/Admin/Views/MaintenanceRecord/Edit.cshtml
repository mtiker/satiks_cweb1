@model WebApp.Areas.Admin.ViewModels.MaintenanceRecord.MaintenanceRecordCreateEditViewModel
@{ ViewData["Title"] = Localizer["EditMaintenanceRecord"]; }

<h2>@Localizer["EditMaintenanceRecord"]</h2>
<hr />
<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit">
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="mb-3">
                <label asp-for="EquipmentId" class="form-label">@Localizer["Equipment"]</label>
                <select asp-for="EquipmentId" asp-items="Model.EquipmentSelectList" class="form-select">
                    <option value="">@Localizer["SelectEquipment"]</option>
                </select>
                <span asp-validation-for="EquipmentId" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="Description" class="form-label"></label>
                <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>
            <div class="row">
                <div class="col mb-3">
                    <label asp-for="ScheduledDate" class="form-label"></label>
                    <input asp-for="ScheduledDate" class="form-control" type="date" />
                    <span asp-validation-for="ScheduledDate" class="text-danger"></span>
                </div>
                <div class="col mb-3">
                    <label asp-for="CompletedDate" class="form-label"></label>
                    <input asp-for="CompletedDate" class="form-control" type="date" />
                </div>
            </div>
            <div class="mb-3">
                <label asp-for="Resolution" class="form-label"></label>
                <textarea asp-for="Resolution" class="form-control" rows="2"></textarea>
            </div>
            <div class="mb-3">
                <label asp-for="Cost" class="form-label"></label>
                <input asp-for="Cost" class="form-control" type="number" step="0.01" min="0" />
            </div>
            <div class="mb-3 form-check">
                <input asp-for="IsScheduled" class="form-check-input" />
                <label asp-for="IsScheduled" class="form-check-label">@Localizer["ScheduledReactive"]</label>
            </div>

            <button type="submit" class="btn btn-primary">@Localizer["Save"]</button>
            <a asp-action="Index" class="btn btn-secondary">@Localizer["BackToList"]</a>
        </form>
    </div>
</div>

@section Scripts { @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); } }