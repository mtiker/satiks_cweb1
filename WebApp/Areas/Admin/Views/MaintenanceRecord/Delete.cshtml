@model App.DTO.v1.MaintenanceRecordDto
@{ ViewData["Title"] = Localizer["DeleteMaintenanceRecord"]; }

<h2>@Localizer["DeleteMaintenanceRecord"]</h2>
<div class="alert alert-danger">@Localizer["ConfirmDeleteMaintenanceRecord", Model.EquipmentName ?? ""]</div>
<dl class="row">
    <dt class="col-sm-3">@Localizer["Equipment"]</dt><dd class="col-sm-9">@Model.EquipmentName</dd>
    <dt class="col-sm-3">@Localizer["Description"]</dt><dd class="col-sm-9">@Model.Description</dd>
    <dt class="col-sm-3">@Localizer["ScheduledDate"]</dt><dd class="col-sm-9">@Model.ScheduledDate.ToString("d")</dd>
</dl>
<form asp-action="Delete">
    <input type="hidden" name="id" value="@Model.Id" />
    <button type="submit" class="btn btn-danger">@Localizer["Delete"]</button>
    <a asp-action="Index" class="btn btn-secondary">@Localizer["Cancel"]</a>
</form>