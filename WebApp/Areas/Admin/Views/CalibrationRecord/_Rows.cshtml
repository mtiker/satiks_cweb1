@model IReadOnlyList<WebApp.Areas.Admin.ViewModels.CalibrationRecord.CalibrationListItem>
@foreach (var item in Model)
{
    <tr>
        <td>
            <a asp-area="Admin" asp-controller="Equipment" asp-action="Details" asp-route-id="@item.EquipmentId">
                @item.EquipmentName
            </a>
        </td>
        <td class="text-muted small">@item.CalibrationDate.ToString("d")</td>
        <td class="text-muted small">@item.NextCalibrationDue.ToString("d")</td>
        <td class="text-muted small">@item.CertificateNumber</td>
        <td>
            @{
                string passedColor = item.PassedFailed switch
                {
                    "true" => "success",
                    "false" => "danger",
                    _ => "secondary"
                };
            }
            <span class="badge bg-@passedColor">
                @{
                    string passedText = item.PassedFailed switch
                    {
                        "true" => "Passed",
                        "false" => "Failed",
                        _ => item.PassedFailed
                    };
                }
                @passedText
        </td>
        <td class="text-muted small">@item.CalibratedByUserName</td>
        <td class="text-end">
            <div class="btn-group btn-group-sm">
                <a asp-area="Admin" asp-controller="CalibrationRecord" asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-primary">Details</a>
                <a asp-area="Admin" asp-controller="CalibrationRecord" asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-secondary">Edit</a>
                <a asp-area="Admin" asp-controller="CalibrationRecord" asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger">Delete</a>
            </div>
        </td>
    </tr>
}
