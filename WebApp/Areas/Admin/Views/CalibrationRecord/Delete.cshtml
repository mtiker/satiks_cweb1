@model App.DTO.v1.CalibrationRecordDto
@{ ViewData["Title"] = Localizer["DeleteCalibrationRecord"]; }

<h2>@Localizer["DeleteCalibrationRecord"]</h2>
<div class="alert alert-danger">@Localizer["ConfirmDeleteCalibrationRecord", Model.EquipmentName ?? ""]</div>
<dl class="row">
    <dt class="col-sm-3">@Localizer["Equipment"]</dt><dd class="col-sm-9">@Model.EquipmentName</dd>
    <dt class="col-sm-3">@Localizer["CalibrationDate"]</dt><dd class="col-sm-9">@Model.CalibrationDate.ToString("d")</dd>
    <dt class="col-sm-3">@Localizer["Result"]</dt><dd class="col-sm-9">@(Model.Passed ? @Localizer["Passed"] : @Localizer["Failed"])</dd>
</dl>
<form asp-action="Delete">
    <input type="hidden" name="id" value="@Model.Id" />
    <button type="submit" class="btn btn-danger">@Localizer["Delete"]</button>
    <a asp-action="Index" class="btn btn-secondary">@Localizer["Cancel"]</a>
</form>