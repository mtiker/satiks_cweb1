@model IReadOnlyList<WebApp.Areas.Admin.ViewModels.TrainingCertification.CertificationListItem>
@foreach (var item in Model)
{
    <tr>
        <td class="text-muted">@item.AppUserFullName</td>
        <td>
            <a asp-area="Admin" asp-controller="EquipmentCategory" asp-action="Details" asp-route-id="@item.EquipmentCategoryId">@item.EquipmentCategoryName</a>
        </td>
        <td class="text-muted small">@item.CertifiedDate.ToString("d")</td>
        <td class="text-muted small">@(item.ExpiryDate.HasValue ? item.ExpiryDate.Value.ToString("d") : "-")</td>
        <td>
            @{
                string statusColor = item.Status switch
                {
                    "Approved" => "success",
                    "Pending" => "warning",
                    "Rejected" => "danger",
                    "Revoked" => "danger",
                    "Expired" => "secondary",
                    _ => "secondary"
                };
            }
            <span class="badge bg-@statusColor">@item.Status</span>
        </td>
        <td class="text-muted small">@item.CertificateReference</td>
        <td class="text-end">
            <div class="btn-group btn-group-sm">
                <a asp-area="Admin" asp-controller="TrainingCertification" asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-primary">Details</a>
                <a asp-area="Admin" asp-controller="TrainingCertification" asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-secondary">Edit</a>
                <a asp-area="Admin" asp-controller="TrainingCertification" asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger">Delete</a>
            </div>
        </td>
    </tr>
}
