@model WebApp.Areas.Admin.ViewModels.TrainingCertification.TrainingCertUpdateStatusViewModel
@{ ViewData["Title"] = Localizer["ReviewCertification"]; }

<h2>@Localizer["ReviewCertification"]</h2>
<hr />
<div class="row">
    <div class="col-md-5">
        <form asp-action="UpdateStatus">
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>

            <div class="mb-3">
                <label asp-for="Status" class="form-label"></label>
                <select asp-for="Status" asp-items="Model.StatusSelectList" class="form-select">
                    <option value="">— Select Status —</option>
                </select>
                <span asp-validation-for="Status" class="text-danger"></span>
            </div>
            <div class="mb-3">
                <label asp-for="ValidationComment" class="form-label"></label>
                <textarea asp-for="ValidationComment" class="form-control" rows="4"
                          placeholder="Optional: reason for approval, rejection, or revocation"></textarea>
            </div>

            <button type="submit" class="btn btn-primary">Save Decision</button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</div>

@section Scripts { @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); } }