@model App.DTO.v1.EquipmentCategoryDto
@{ ViewData["Title"] = Localizer["EquipmentCategoryDetails"]; }

<h2>@Localizer["EquipmentCategoryDetails"]</h2>
<hr />
<dl class="row">
    <dt class="col-sm-3">Name (EN)</dt><dd class="col-sm-9">@Model.NameEn</dd>
    <dt class="col-sm-3">Name (ET)</dt><dd class="col-sm-9">@Model.NameEt</dd>
    <dt class="col-sm-3">Description</dt><dd class="col-sm-9">@Model.Description</dd>
    <dt class="col-sm-3">Requires Training</dt>
    <dd class="col-sm-9">
        <span class="badge bg-@(Model.RequiresTraining ? "warning" : "secondary")">
            @(Model.RequiresTraining ? "Yes" : "No")
        </span>
    </dd>
    <dt class="col-sm-3">Equipment Count</dt><dd class="col-sm-9">@Model.EquipmentCount</dd>
</dl>
<a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">@Localizer["Edit"]</a>
<a asp-action="Index" class="btn btn-secondary">@Localizer["BackToList"]</a>