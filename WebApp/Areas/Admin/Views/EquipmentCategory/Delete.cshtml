@model App.DTO.v1.EquipmentCategoryDto
@{ ViewData["Title"] = Localizer["Delete"] + " " + Localizer["Category"]; }

<h2>@Localizer["Delete"] + " " + @Localizer["Category"]</h2>
<div class="alert alert-danger">@Localizer["ConfirmDeleteEquipmentCategory", Model.Name]</div>
<dl class="row">
    <dt class="col-sm-3">@Localizer["Name"]</dt><dd class="col-sm-9">@Model.Name</dd>
    <dt class="col-sm-3">@Localizer["RequiresTraining"]</dt><dd class="col-sm-9">@(Model.RequiresTraining ? @Localizer["Yes"] : @Localizer["No"])</dd>
    <dt class="col-sm-3">@Localizer["EquipmentCount"]</dt><dd class="col-sm-9">@Model.EquipmentCount</dd>
</dl>
<form asp-action="Delete">
    <input type="hidden" name="id" value="@Model.Id" />
    <button type="submit" class="btn btn-danger">@Localizer["Delete"]</button>
    <a asp-action="Index" class="btn btn-secondary">@Localizer["Cancel"]</a>
</form>