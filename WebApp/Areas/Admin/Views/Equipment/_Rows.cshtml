@model IReadOnlyList<WebApp.Areas.Admin.ViewModels.Equipment.EquipmentListItem>
@foreach (var item in Model)
{
    <tr>
        <td>@item.Name</td>
        <td class="text-muted small">@item.SerialNumber</td>
        <td>
            <a asp-area="Admin" asp-controller="Laboratory" asp-action="Details" asp-route-id="@item.LaboratoryId">
                @item.LaboratoryName
            </a>
        </td>
        <td>@item.CategoryName</td>
        <td>
            @{
                string conditionColor = item.EquipmentCondition switch
                {
                    "New" => "success",
                    "Good" => "info",
                    "Fair" => "warning",
                    "NeedsRepair" => "danger",
                    "Decommissioned" => "secondary",
                    _ => "secondary"
                };
            }
            <span class="badge bg-@conditionColor">@item.EquipmentCondition</span>
        </td>
        <td>
            @if (item.AvailabilityStatus == "Available")
            {
                <span class="badge bg-success">Yes</span>
            }
            else
            {
                <span class="badge bg-danger">No</span>
            }
        </td>
        <td>
            @if (item.RequiresTraining)
            {
                <span class="badge bg-warning">Yes</span>
            }
            else
            {
                <span class="badge bg-secondary">No</span>
            }
        </td>
        <td class="text-end">
            <div class="btn-group btn-group-sm">
                <a asp-area="Admin" asp-controller="Equipment" asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-primary">Details</a>
                <a asp-area="Admin" asp-controller="Equipment" asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-secondary">Edit</a>
                <a asp-area="Admin" asp-controller="Equipment" asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger">Delete</a>
            </div>
        </td>
    </tr>
}
