@model App.DTO.v1.EquipmentDto
@{ ViewData["Title"] = Localizer["Delete"] + " " + Localizer["Equipment"]; }

<h2>@Localizer["Delete"] + " " + @Localizer["Equipment"]</h2>
<div class="alert alert-danger">@Localizer["ConfirmDeleteEquipment", Model.Name]</div>
<dl class="row">
    <dt class="col-sm-3">@Localizer["Name"]</dt><dd class="col-sm-9">@Model.Name</dd>
    <dt class="col-sm-3">@Localizer["SerialNumber"]</dt><dd class="col-sm-9">@Model.SerialNumber</dd>
    <dt class="col-sm-3">@Localizer["Laboratory"]</dt><dd class="col-sm-9">@Model.LaboratoryName</dd>
    <dt class="col-sm-3">@Localizer["Category"]</dt><dd class="col-sm-9">@Model.CategoryName</dd>
</dl>
<form asp-action="Delete">
    <input type="hidden" name="id" value="@Model.Id" />
    <button type="submit" class="btn btn-danger">@Localizer["Delete"]</button>
    <a asp-action="Index" class="btn btn-secondary">@Localizer["Cancel"]</a>
</form>