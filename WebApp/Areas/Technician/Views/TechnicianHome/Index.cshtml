@model TechnicianDashboardViewModel

@{
    ViewData["Title"] = "Technician Dashboard";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="bi bi-speedometer2 me-2 text-warning"></i>Technician Dashboard</h2>
</div>

<div class="row g-4 mb-4">
    <div class="col-md-6">
        <div class="card border-warning shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="fs-1 text-warning"><i class="bi bi-wrench-adjustable-circle"></i></div>
                <div>
                    <div class="fs-2 fw-bold">@Model.ScheduledMaintenanceCount</div>
                    <div class="text-muted">Scheduled Maintenance Tasks</div>
                </div>
            </div>
            <div class="card-footer bg-transparent border-warning">
                <a asp-area="Technician" asp-controller="Maintenance" asp-action="Index"
                   asp-route-status="scheduled" class="btn btn-sm btn-outline-warning">
                    View Scheduled →
                </a>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card border-danger shadow-sm h-100">
            <div class="card-body d-flex align-items-center gap-3">
                <div class="fs-1 text-danger"><i class="bi bi-rulers"></i></div>
                <div>
                    <div class="fs-2 fw-bold">@Model.OverdueCalibrationCount</div>
                    <div class="text-muted">Overdue Calibrations</div>
                </div>
            </div>
            <div class="card-footer bg-transparent border-danger">
                <a asp-area="Technician" asp-controller="Calibration" asp-action="Index"
                   class="btn btn-sm btn-outline-danger">
                    View Calibrations →
                </a>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-header fw-semibold">
                <i class="bi bi-wrench me-2"></i>Recent Maintenance
            </div>
            <div class="list-group list-group-flush">
                @if (!Model.RecentMaintenance.Any())
                {
                    <div class="list-group-item text-muted">No records found.</div>
                }
                else
                {
                    @foreach (var m in Model.RecentMaintenance)
                    {
                        var statusBadge = (m.IsScheduled && !m.CompletedDate.HasValue)
                            ? "<span class='badge bg-warning text-dark'>Scheduled</span>"
                            : "<span class='badge bg-success'>Completed</span>";
                        <a asp-area="Technician" asp-controller="Maintenance" asp-action="Details"
                           asp-route-id="@m.Id"
                           class="list-group-item list-group-item-action d-flex justify-content-between align-items-start">
                            <div>
                                <div class="fw-semibold">@m.EquipmentName</div>
                                <small class="text-muted">@m.Description.Substring(0, Math.Min(60, m.Description.Length))@(m.Description.Length > 60 ? "…" : "")</small>
                            </div>
                            @Html.Raw(statusBadge)
                        </a>
                    }
                }
            </div>
            <div class="card-footer">
                <a asp-area="Technician" asp-controller="Maintenance" asp-action="Index"
                   class="btn btn-sm btn-outline-secondary">All Maintenance Records →</a>
            </div>
        </div>
    </div>

    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-header fw-semibold">
                <i class="bi bi-rulers me-2"></i>Recent Calibrations
            </div>
            <div class="list-group list-group-flush">
                @if (!Model.RecentCalibrations.Any())
                {
                    <div class="list-group-item text-muted">No records found.</div>
                }
                else
                {
                    @foreach (var c in Model.RecentCalibrations)
                    {
                        var overdueClass = c.NextCalibrationDue < DateTime.UtcNow ? "list-group-item-danger" : "";
                        <a asp-area="Technician" asp-controller="Calibration" asp-action="Details"
                           asp-route-id="@c.Id"
                           class="list-group-item list-group-item-action @overdueClass d-flex justify-content-between align-items-start">
                            <div>
                                <div class="fw-semibold">@c.EquipmentName</div>
                                <small class="text-muted">Due: @c.NextCalibrationDue.ToString("d")</small>
                            </div>
                            @if (c.Passed)
                            {
                                <span class="badge bg-success">Passed</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Failed</span>
                            }
                        </a>
                    }
                }
            </div>
            <div class="card-footer">
                <a asp-area="Technician" asp-controller="Calibration" asp-action="Index"
                   class="btn btn-sm btn-outline-secondary">All Calibration Records →</a>
            </div>
        </div>
    </div>
</div>
