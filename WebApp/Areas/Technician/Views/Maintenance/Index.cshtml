@model IEnumerable<App.DTO.v1.MaintenanceRecordDto>

@{
    ViewData["Title"] = "Maintenance Records";
    var equipmentList = ViewBag.EquipmentSelectList as Microsoft.AspNetCore.Mvc.Rendering.SelectList;
    var statusList    = ViewBag.StatusSelectList    as Microsoft.AspNetCore.Mvc.Rendering.SelectList;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-wrench-adjustable me-2"></i>Maintenance Records</h2>
</div>

<form method="get" class="row g-2 mb-4">
    <div class="col-md-4">
        <select name="equipmentId" class="form-select form-select-sm" asp-items="equipmentList">
            <option value="">— All Equipment —</option>
        </select>
    </div>
    <div class="col-md-3">
        <select name="status" class="form-select form-select-sm" asp-items="statusList">
        </select>
    </div>
    <div class="col-md-2">
        <button type="submit" class="btn btn-sm btn-primary w-100">Filter</button>
    </div>
    <div class="col-md-2">
        <a asp-area="Technician" asp-controller="Maintenance" asp-action="Index"
           class="btn btn-sm btn-outline-secondary w-100">Clear</a>
    </div>
</form>

<div class="table-responsive">
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th>Equipment</th>
                <th>Scheduled Date</th>
                <th>Completed Date</th>
                <th>Description</th>
                <th>Status</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="6" class="text-center text-muted py-4">No records found.</td>
                </tr>
            }
            else
            {
                @foreach (var item in Model)
                {
                    var isScheduled = item.IsScheduled && !item.CompletedDate.HasValue;
                    <tr>
                        <td>@(item.EquipmentName ?? "—")</td>
                        <td>@item.ScheduledDate.ToString("d")</td>
                        <td>@(item.CompletedDate?.ToString("d") ?? "—")</td>
                        <td>
                            @(item.Description.Length > 60
                                ? item.Description.Substring(0, 60) + "…"
                                : item.Description)
                        </td>
                        <td>
                            @if (isScheduled)
                            {
                                <span class="badge bg-warning text-dark">Scheduled</span>
                            }
                            else
                            {
                                <span class="badge bg-success">Completed</span>
                            }
                        </td>
                        <td class="text-end">
                            <a asp-area="Technician" asp-controller="Maintenance" asp-action="Details"
                               asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Details</a>
                            <a asp-area="Technician" asp-controller="Maintenance" asp-action="Edit"
                               asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning ms-1">Edit</a>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>
