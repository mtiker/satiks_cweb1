@model App.DTO.v1.MaintenanceRecordDto

@{
    ViewData["Title"] = "Maintenance Details";
    var isScheduled = Model.IsScheduled && !Model.CompletedDate.HasValue;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-wrench-adjustable me-2"></i>Maintenance Details</h2>
    <div>
        <a asp-area="Technician" asp-controller="Maintenance" asp-action="Edit"
           asp-route-id="@Model.Id" class="btn btn-outline-warning btn-sm">
            <i class="bi bi-pencil me-1"></i>Edit
        </a>
        <a asp-area="Technician" asp-controller="Maintenance" asp-action="Index"
           class="btn btn-outline-secondary btn-sm ms-1">
            <i class="bi bi-arrow-left me-1"></i>Back
        </a>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span class="fw-semibold">@(Model.EquipmentName ?? "Unknown Equipment")</span>
        @if (isScheduled)
        {
            <span class="badge bg-warning text-dark fs-6">Scheduled</span>
        }
        else
        {
            <span class="badge bg-success fs-6">Completed</span>
        }
    </div>
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Equipment</dt>
            <dd class="col-sm-9">@(Model.EquipmentName ?? "—")</dd>

            <dt class="col-sm-3">Scheduled Date</dt>
            <dd class="col-sm-9">@Model.ScheduledDate.ToString("g")</dd>

            <dt class="col-sm-3">Completed Date</dt>
            <dd class="col-sm-9">@(Model.CompletedDate?.ToString("g") ?? "—")</dd>

            <dt class="col-sm-3">Description</dt>
            <dd class="col-sm-9">@Model.Description</dd>

            <dt class="col-sm-3">Resolution</dt>
            <dd class="col-sm-9">@(Model.Resolution ?? "—")</dd>

            <dt class="col-sm-3">Cost</dt>
            <dd class="col-sm-9">@(Model.Cost.HasValue ? $"€{Model.Cost:F2}" : "—")</dd>

            <dt class="col-sm-3">Performed By</dt>
            <dd class="col-sm-9">@(Model.PerformedByUserName ?? "—")</dd>
        </dl>
    </div>
</div>
