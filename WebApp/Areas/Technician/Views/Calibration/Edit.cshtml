@model CalibrationEditViewModel

@{
    ViewData["Title"] = "Update Calibration Record";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-pencil-square me-2 text-warning"></i>Update Calibration Record</h2>
</div>

<div class="row">
    <div class="col-md-7">
        <div class="card shadow-sm">
            <div class="card-header bg-warning text-dark fw-semibold">
                <i class="bi bi-rulers me-2"></i>@Model.EquipmentName
            </div>
            <div class="card-body">
                <form asp-area="Technician" asp-controller="Calibration" asp-action="Edit"
                      asp-route-id="@Model.Id" method="post">
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="EquipmentName" />

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label asp-for="CertificateNumber" class="form-label fw-semibold">Certificate Number</label>
                        <input asp-for="CertificateNumber" class="form-control"
                               placeholder="e.g. CAL-2026-001" />
                        <span asp-validation-for="CertificateNumber" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="NextCalibrationDue" class="form-label fw-semibold">
                            Next Calibration Due <span class="text-danger">*</span>
                        </label>
                        <input asp-for="NextCalibrationDue" type="datetime-local" class="form-control" />
                        <span asp-validation-for="NextCalibrationDue" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Result</label>
                        <div class="d-flex gap-4">
                            <div class="form-check">
                                <input class="form-check-input" type="radio" asp-for="Passed"
                                       id="passedTrue" value="true" />
                                <label class="form-check-label text-success fw-semibold" for="passedTrue">
                                    <i class="bi bi-check-circle me-1"></i>Passed
                                </label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" asp-for="Passed"
                                       id="passedFalse" value="false" />
                                <label class="form-check-label text-danger fw-semibold" for="passedFalse">
                                    <i class="bi bi-x-circle me-1"></i>Failed
                                </label>
                            </div>
                        </div>
                        <span asp-validation-for="Passed" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Notes" class="form-label fw-semibold">Notes</label>
                        <textarea asp-for="Notes" class="form-control" rows="4"
                                  placeholder="Add calibration notes, observations, or remarks…"></textarea>
                        <span asp-validation-for="Notes" class="text-danger small"></span>
                    </div>

                    <div class="d-flex gap-2 mt-3">
                        <button type="submit" class="btn btn-warning">
                            <i class="bi bi-save me-1"></i>Save Changes
                        </button>
                        <a asp-area="Technician" asp-controller="Calibration" asp-action="Index"
                           class="btn btn-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }
}
