@model App.DTO.v1.CalibrationRecordDto

@{
    ViewData["Title"] = "Calibration Details";
    var overdue = Model.NextCalibrationDue < DateTime.UtcNow;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-rulers me-2"></i>Calibration Details</h2>
    <div>
        <a asp-area="Technician" asp-controller="Calibration" asp-action="Edit"
           asp-route-id="@Model.Id" class="btn btn-outline-warning btn-sm">
            <i class="bi bi-pencil me-1"></i>Edit
        </a>
        <a asp-area="Technician" asp-controller="Calibration" asp-action="Index"
           class="btn btn-outline-secondary btn-sm ms-1">
            <i class="bi bi-arrow-left me-1"></i>Back
        </a>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-header d-flex justify-content-between align-items-center">
        <span class="fw-semibold">@(Model.EquipmentName ?? "Unknown Equipment")</span>
        <div class="d-flex gap-2">
            @if (overdue)
            {
                <span class="badge bg-danger fs-6">Overdue</span>
            }
            @if (Model.Passed)
            {
                <span class="badge bg-success fs-6">Passed</span>
            }
            else
            {
                <span class="badge bg-danger fs-6">Failed</span>
            }
        </div>
    </div>
    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Equipment</dt>
            <dd class="col-sm-9">@(Model.EquipmentName ?? "—")</dd>

            <dt class="col-sm-3">Calibration Date</dt>
            <dd class="col-sm-9">@Model.CalibrationDate.ToString("g")</dd>

            <dt class="col-sm-3">Next Calibration Due</dt>
            <dd class="col-sm-9">
                @Model.NextCalibrationDue.ToString("d")
                @if (overdue)
                {
                    <span class="badge bg-danger ms-2">Overdue</span>
                }
            </dd>

            <dt class="col-sm-3">Certificate Number</dt>
            <dd class="col-sm-9">@(Model.CertificateNumber ?? "—")</dd>

            <dt class="col-sm-3">Result</dt>
            <dd class="col-sm-9">
                @if (Model.Passed)
                {
                    <span class="text-success fw-semibold"><i class="bi bi-check-circle me-1"></i>Passed</span>
                }
                else
                {
                    <span class="text-danger fw-semibold"><i class="bi bi-x-circle me-1"></i>Failed</span>
                }
            </dd>

            <dt class="col-sm-3">Notes</dt>
            <dd class="col-sm-9">@(Model.Notes ?? "—")</dd>

            <dt class="col-sm-3">Calibrated By</dt>
            <dd class="col-sm-9">@(Model.CalibratedByUserName ?? "—")</dd>
        </dl>
    </div>
</div>
