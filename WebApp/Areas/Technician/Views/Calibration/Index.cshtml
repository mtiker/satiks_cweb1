@model IEnumerable<App.DTO.v1.CalibrationRecordDto>

@{
    ViewData["Title"] = "Calibration Records";
    var equipmentList = ViewBag.EquipmentSelectList as Microsoft.AspNetCore.Mvc.Rendering.SelectList;
    var passedList    = ViewBag.PassedSelectList    as Microsoft.AspNetCore.Mvc.Rendering.SelectList;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-rulers me-2"></i>Calibration Records</h2>
</div>

<form method="get" class="row g-2 mb-4">
    <div class="col-md-4">
        <select name="equipmentId" class="form-select form-select-sm" asp-items="equipmentList">
            <option value="">— All Equipment —</option>
        </select>
    </div>
    <div class="col-md-3">
        <select name="passed" class="form-select form-select-sm" asp-items="passedList">
        </select>
    </div>
    <div class="col-md-2">
        <button type="submit" class="btn btn-sm btn-primary w-100">Filter</button>
    </div>
    <div class="col-md-2">
        <a asp-area="Technician" asp-controller="Calibration" asp-action="Index"
           class="btn btn-sm btn-outline-secondary w-100">Clear</a>
    </div>
</form>

<div class="table-responsive">
    <table class="table table-striped align-middle">
        <thead>
            <tr>
                <th>Equipment</th>
                <th>Calibration Date</th>
                <th>Next Due</th>
                <th>Certificate #</th>
                <th>Result</th>
                <th class="text-end">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="6" class="text-center text-muted py-4">No records found.</td>
                </tr>
            }
            else
            {
                @foreach (var item in Model)
                {
                    var overdue = item.NextCalibrationDue < DateTime.UtcNow;
                    <tr class="@(overdue ? "table-danger" : "")">
                        <td>@(item.EquipmentName ?? "—")</td>
                        <td>@item.CalibrationDate.ToString("d")</td>
                        <td>
                            @item.NextCalibrationDue.ToString("d")
                            @if (overdue)
                            {
                                <span class="badge bg-danger ms-1">Overdue</span>
                            }
                        </td>
                        <td>@(item.CertificateNumber ?? "—")</td>
                        <td>
                            @if (item.Passed)
                            {
                                <span class="badge bg-success">Passed</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Failed</span>
                            }
                        </td>
                        <td class="text-end">
                            <a asp-area="Technician" asp-controller="Calibration" asp-action="Details"
                               asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Details</a>
                            <a asp-area="Technician" asp-controller="Calibration" asp-action="Edit"
                               asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning ms-1">Edit</a>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>
